{
  "expo": {
    "name": "exposhell",
    "slug": "exposhell",
    "scheme":"exposhell",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "packagerOpts": {
      "sourceMap": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourname.exposhell",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.BLUETOOTH_SCAN"
      ]
    },
    "plugins": [
      "expo-share-intent",
      "expo-dev-client",
      "expo-sensors",
      "expo-location",
      "expo-camera",
      "expo-audio",
      "expo-secure-store",
      "expo-sqlite",
      "expo-file-system",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "central", "peripheral"
          ],
          "bluetoothAlwaysPermission": "Allow $(PRODUCT_NAME) to use Bluetooth even when you are not using the app."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "d2fc2326-310b-4bbe-b02b-382d68b95e22"
      }
    },
    "ios": {
      "bundleIdentifier": "com.yourname.exposhell"
    }
  }
}
